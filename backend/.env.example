# Database
DATABASE_URL=sqlite+aiosqlite:///./data/api_pilot.db

# Auth
API_PILOT_SECRET_KEY=your-secret-key-here-change-in-production
API_PILOT_ALGORITHM=HS256
API_PILOT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:8081

# Cloudflare Turnstile (get from https://dash.cloudflare.com/turnstile)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Environment
ENV=development